# Copy this file to .env and fill in real values before running the server.

# Django
SECRET_KEY=change-this-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# PostgreSQL database
DB_NAME=ecommerce_db
DB_USER=ecommerce_user
DB_PASSWORD=change-this-password
DB_HOST=127.0.0.1
DB_PORT=5432

# Frontend origin(s) allowed to call the API (comma separated)
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,http://127.0.0.1:8080,http://localhost:8080
